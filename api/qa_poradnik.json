    "html": "<style>\n    .sps-frame {\n        max-width: 100%;\n        margin: 0 auto;\n        background: #fff;\n        border-radius: 10px;\n        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n        overflow: hidden\n    }\n\n    .sps-top-bar {\n        background: #333;\n        padding: 10px 18px;\n        display: flex;\n        gap: 6px\n    }\n\n    .sps-dot {\n        width: 10px;\n        height: 10px;\n        border-radius: 50%\n    }\n\n    .dot-r {\n        background: #ff5f56\n    }\n\n    .dot-y {\n        background: #ffbd2e\n    }\n\n    .dot-g {\n        background: #27c93f\n    }\n\n    .sps-section-title {\n        background: #f4f0ff;\n        padding: 40px 50px;\n        position: relative\n    }\n\n    .sps-section-title::before {\n        content: \"\";\n        position: absolute;\n        left: 25px;\n        top: 40px;\n        bottom: 40px;\n        width: 4px;\n        background: #a55eea\n    }\n\n    .sps-h1 {\n        font-size: 30px;\n        font-weight: 800;\n        color: #222;\n        margin: 0 0 8px 0;\n        line-height: 1.2\n    }\n\n    .sps-section-question {\n        background: #fff5e6;\n        padding: 40px 50px\n    }\n\n    .qa-label {\n        font-size: 11px;\n        font-weight: 900;\n        text-transform: uppercase;\n        letter-spacing: 1px;\n        margin-bottom: 12px\n    }\n\n    .qa-label-q {\n        color: #a55eea\n    }\n\n    .qa-label-a {\n        color: #27ae60\n    }\n\n    .qa-question {\n        font-size: 22px;\n        font-weight: 800;\n        color: #222;\n        line-height: 1.4;\n        margin: 0\n    }\n\n    .sps-section-answer {\n        background: #f0f7ff;\n        padding: 40px 50px\n    }\n\n    .qa-answer {\n        font-size: 16px;\n        line-height: 1.8;\n        color: #333;\n        margin: 0\n    }\n\n    .sps-section-conclusion {\n        background: #eafff2;\n        padding: 40px 50px;\n        border-top: 1px solid #d4f0de\n    }\n\n    .cta-button {\n        display: block;\n        width: fit-content;\n        margin: 30px auto 0;\n        background: #a55eea;\n        color: #fff !important;\n        padding: 16px 40px;\n        border-radius: 4px;\n        text-decoration: none;\n        font-weight: bold;\n        text-transform: uppercase;\n        letter-spacing: 1px\n    }\n\n    @media(max-width:768px) {\n\n        .sps-section-title,\n        .sps-section-question,\n        .sps-section-answer,\n        .sps-section-conclusion {\n            padding: 30px 20px\n        }\n    }\n</style>\n\n<div class=\"sps-frame\">\n    <div class=\"sps-top-bar\">\n        <div class=\"sps-dot dot-r\"></div>\n        <div class=\"sps-dot dot-y\"></div>\n        <div class=\"sps-dot dot-g\"></div>\n    </div>\n\n    <div class=\"sps-section-title\">\n        <h1 class=\"sps-h1\">Gdzie konto firmowe...</h1>\n    </div>\n\n    <div class=\"sps-section-question\">\n        <div class=\"qa-label qa-label-q\">❓ Pytanie</div>\n        <p class=\"qa-question\">Gdzie założyć konto firmowe...</p>\n    </div>\n\n    <div class=\"sps-section-answer\">\n        <div class=\"qa-label qa-label-a\">✅ Odpowiedź</div>\n        <p class=\"qa-answer\">Oddział w każdym mieście...</p>\n        {% if a2 %}\n        <p class=\"qa-answer\">(dodatkowe informacje)</p>\n        {% endif %}\n        {% if a3 %}\n        <p class=\"qa-answer\">(dodatkowe informacje)</p>\n        {% endif %}\n    </div>\n\n    <div class=\"sps-section-conclusion\">\n        <a href=\"https://...\" class=\"cta-button\">(ten sam co tytul?)</a>\n    </div>\n</div>"
  }
]